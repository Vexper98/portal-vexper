{
  "name": "AgentLog",
  "type": "object",
  "properties": {
    "companyId": {
      "type": "string",
      "description": "ID da empresa"
    },
    "filename": {
      "type": "string",
      "description": "Nome do arquivo relacionado"
    },
    "message": {
      "type": "string",
      "description": "Mensagem do log"
    },
    "level": {
      "type": "string",
      "enum": [
        "info",
        "warning",
        "error"
      ],
      "default": "info"
    }
  },
  "required": [
    "companyId",
    "message"
  ]
}